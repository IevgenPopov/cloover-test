generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String    @id @default(uuid())
  name         String
  email        String    @unique
  role         String    @default("user")
  salt         String
  passwordHash String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  accounts     Account[]
  quotes       Quote[]

  @@map("cloover_users")
}

model Account {
  id                String   @id @default(uuid())
  provider          String
  providerAccountId String
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())

  @@unique([provider, providerAccountId])
  @@map("cloover_accounts")
}

model Quote {
  id          String   @id @default(uuid())
  date        DateTime
  systemSize  Float
  price       Float
  downPayment Float?
  band        String
  description String
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("cloover_quotes")
}
